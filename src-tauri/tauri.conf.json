{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gebinee",
  "version": "1.0.0",
  "identifier": "com.gebinee.gebinee",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gebinee",
        "width": 900,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "appimage",
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "resources": [
      "resources/word.sqlite"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "scripts/nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0QTlDRTA2MTczRTdFNkIKUldScmZqNFhCczZweEh2QlEyTUJEM1ZnQldJNFRCNXVrQ0lodEJPZVdlMkFWaXgyaXhyN25GT0UK",
      "endpoints": [
        "https://github.com/gebinee/update-info/releases/download/gebinee/latest.json",
        "https://gh-proxy.org/https://github.com/gebinee/update-info/releases/download/gebinee/latest-proxy.json"
      ]
    },
    "process": {}
  }
}
